# dependencies
/node_modules

# next.js
/.next
/out

# production
/build

# local runtime state (server-side clone + sqlite) — never commit
/data/*
# ...but DO commit the generated theme architecture map (read at request time)
!/data/architecture

# env — secrets, never commit
.env
.env.local
.env*.local
.env.production

# misc
.DS_Store
*.pem
*.log
npm-debug.log*

# editor
.vscode
.idea

# keep the mockup out of the build; it's a reference artifact
/publish-console-mockup.jsx
