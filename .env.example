# =============================================================================
# Publish Console — environment
# Copy to `.env` (dev) or `.env.production` (droplet). NEVER commit the filled-in
# file. On the droplet, `chmod 600 .env.production`.
#
# TWO TIERS:
#  - BOOTSTRAP (this file only): needed before login/settings exist. Editing means
#    editing this file + restart. Kept here so an admin can't lock themselves out.
#  - MANAGED IN-APP (optional here): the super-admin can set/override these live in
#    the app's Settings panel (stored encrypted in sqlite). Values here act as
#    fallbacks/defaults until overridden in-app. Marked [in-app] below.
# =============================================================================

# ---- BOOTSTRAP: App / server ------------------------------------------------
NEXTAUTH_URL=http://localhost:3008
# Random 32+ byte secret: `openssl rand -base64 32`
NEXTAUTH_SECRET=
# Key used to encrypt in-app secrets at rest. Defaults to NEXTAUTH_SECRET if unset;
# set a dedicated one in production: `openssl rand -base64 32`
SETTINGS_ENCRYPTION_KEY=

# ---- BOOTSTRAP: GitHub OAuth (login / identity) -----------------------------
# GitHub OAuth App — Authorization callback URL must be
#   <NEXTAUTH_URL>/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ---- BOOTSTRAP: auth boundary ----------------------------------------------
# The org whose members may sign in. Also, comma-separated GitHub logins that get
# super-admin (the in-app Settings panel) and are always allowed in.
# The org everyone must belong to for access is `moment-skis`. SUPER_ADMIN_LOGINS
# is your personal GitHub account (always allowed in, even if not a moment-skis member).
GITHUB_ORG=moment-skis
SUPER_ADMIN_LOGINS=valiermedia

# ---- [in-app] Repo & branches ----------------------------------------------
# The Shopify THEME repo the console operates on (NOT this app's own repo). Login is
# granted to moment-skis members with write access to GITHUB_OWNER/GITHUB_REPO.
# The super-admin can change these in Settings after launch.
GITHUB_OWNER=moment-skis
GITHUB_REPO=moment-skis-theme
LIVE_BRANCH=live
STAGING_BRANCH=staging

# ---- [in-app] GitHub App (all repo WRITES go through this installation) ------
# Installed on the org with Contents: read/write and Pull requests: read/write.
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
# Private key (PEM): set it in the Settings panel (stored encrypted), OR provide a
# file path here for first boot. Inline value / in-app value wins over the path.
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_APP_PRIVATE_KEY=

# ---- BOOTSTRAP: server-side clone -------------------------------------------
# Git operations (conflict detection, merges, reverts) run in this maintained clone.
REPO_CLONE_PATH=./data/repo

# ---- [in-app] Shopify (READ-ONLY — there is NO publish code path) -----------
# Admin API token with READ scope only (read_themes). Set in Settings (encrypted).
SHOPIFY_STORE_DOMAIN=moment-skis.myshopify.com
SHOPIFY_ADMIN_API_TOKEN=
SHOPIFY_API_VERSION=2025-01

# ---- [in-app] Client-facing strings ----------------------------------------
DEV_EMAIL=developer@momentskis.com
STORE_PUBLIC_DOMAIN=momentskis.com

# ---- BOOTSTRAP: local state -------------------------------------------------
# SQLite file for QA sign-offs, audit log, and the in-app settings store.
DATABASE_PATH=./data/console.db
